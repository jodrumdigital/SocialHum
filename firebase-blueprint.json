{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "selectedPackage": { "type": "string", "enum": ["starter", "standard", "authority"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Strategy": {
      "title": "Social Media Strategy",
      "description": "A generated strategy for a user's business.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's UID" },
        "businessName": { "type": "string" },
        "industry": { "type": "string" },
        "targetAudience": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "tone": { "type": "string" },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessName"]
    },
    "ContentItem": {
      "title": "Content Item",
      "description": "A specific post or content piece generated based on a strategy.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "strategyId": { "type": "string" },
        "platform": { "type": "string" },
        "caption": { "type": "string" },
        "imageUrl": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "strategyId", "caption"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Business strategies"
    },
    "/content/{contentId}": {
      "schema": "ContentItem",
      "description": "Generated content items"
    }
  }
}
